# =============================================================================
# DATABASE — pick ONE setup
# =============================================================================

# --- A) Hostinger Node.js (app + DB on same server) ---
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_USER=u998538981_writeguard
# DB_PASSWORD=your_mysql_password
# DB_NAME=u998538981_writeguard

# --- B) Vercel + Hostinger Remote MySQL (app on Vercel, DB on Hostinger) ---
# 1. Hostinger hPanel → Databases → Remote MySQL → allow host: %
# 2. Copy the REMOTE MySQL hostname (NOT localhost) e.g. srv1234.hstgr.io
# 3. Set these in Vercel → Project → Settings → Environment Variables:
#
# DB_HOST=srv1234.hstgr.io
# DB_PORT=3306
# DB_USER=u998538981_writeguard
# DB_PASSWORD=your_mysql_password
# DB_NAME=u998538981_writeguard
#
# Or: DATABASE_URL=mysql://USER:PASSWORD@srv1234.hstgr.io:3306/DATABASE_NAME

# --- Alternate env names (same values) ---
# MYSQL_HOST=...
# MYSQL_USER=...
# MYSQL_PASSWORD=...
# MYSQL_DATABASE=...

# Delete any old PostgreSQL/Supabase DATABASE_URL!

# =============================================================================
# AUTH
# =============================================================================
AUTH_SECRET=
AUTH_URL=https://your-domain.vercel.app
NEXTAUTH_URL=https://your-domain.vercel.app
NEXT_PUBLIC_APP_URL=https://your-domain.vercel.app
AUTH_TRUST_HOST=true

# SaaS owner — gets ADMIN role, unlimited usage, /admin panel (comma-separated)
OWNER_EMAIL=atiffortunetech@gmail.com

# After deploy: import mysql/user-access-migration.sql for admin credit controls
# After deploy: import mysql/brand-image-blob-migration.sql for Brand Image Studio on Vercel
OPENAI_API_KEY=

# Optional — Supabase Storage for brand images (otherwise images stored in MySQL)
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=
