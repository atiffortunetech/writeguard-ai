# Database — Hostinger MySQL
# Hostinger docs use DB_* names; this app also accepts MYSQL_* (same values).

# Option A — Hostinger official names (recommended):
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=u998538981_writeguard
DB_PASSWORD=your_mysql_password_here
DB_NAME=u998538981_writeguard

# Option B — alternate names (same values):
# MYSQL_HOST=127.0.0.1
# MYSQL_USER=u998538981_writeguard
# MYSQL_PASSWORD=your_mysql_password_here
# MYSQL_DATABASE=u998538981_writeguard

# Option C — single URL (encode special chars in password: !=%21 @=%40 #=%23):
# DATABASE_URL=mysql://USER:PASSWORD@127.0.0.1:3306/DATABASE_NAME

# IMPORTANT: Delete any old PostgreSQL/Supabase DATABASE_URL from Hostinger!
# Do NOT wrap passwords in quotes in the Hostinger panel.

# Auth (production)
AUTH_SECRET=
AUTH_URL=https://writeguard-ai.amzdudes.io
NEXTAUTH_URL=https://writeguard-ai.amzdudes.io
NEXT_PUBLIC_APP_URL=https://writeguard-ai.amzdudes.io
AUTH_TRUST_HOST=true

# OpenAI
OPENAI_API_KEY=
